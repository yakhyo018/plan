<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>REJA</title>
    <link
      rel="stylesheet"
      href="https://stackpath.bootstrapcdn.com/bootstrap/4.2.1/css/bootstrap.min.css"
      integrity="sha384-GJzZqFGwb1QTTN6wy59ffF1BuGJpLSa9DkKMp0DgiMDm4iYMj70gZWKYbI706tWS"
      crossorigin="anonymous"
    />
  </head>
  <body style="background-color: #b8bbd1">
    <div class="container">
      <h1 class="display-4 text-center py-1">REJA VA MAQSADLAR</h1>
    </div>

    <div class="jumbotron p-3 shadow-sm">
  <form id="create-form" action="/create-item" method="POST">
    <div class="d-flex align-items-center">
      <input
        id="create-field"
        name="Reja"
        autofocus
        autocomplete="off"
        class="form-control mr-3"
        type="text"
        style="flex: 1"
      />
      <button class="btn btn-primary" style="border-radius: 20px">
        Yangi reja Qoshish
      </button>
    </div>
  </form>
  </div> 

  <%= items[0].reja %>

  <ul id="item-list" class="list-group pb-5">
    <li
    class="list-group-item list-group-item-info d-flex align-items-center justify-content-between"
    >
    <span class="item-text"></span>
    <div>
      <button class="edit-me btn btn-secondary btn-sm mr-1">
        ozgartirish
      </button>
      <button class="delete-me btn btn-denger btn-sm">ochirish</button>
    </div>
    </li>

  </ul>

  
  </body>
</html>
 