<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/main.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <title>Portfolio</title>
</head>

<body>
   <div class="frame">
    <div class="main_frame">
        <div class="left_frame">
            <div class="left_1">
                <div class="left_1-1">
                    <img 
                      src="images/profile.png" 
                      width="156px"
                      height="142px" 
                      alt=""
                    />
                </div>
                <div class="left_1-2"><%=user.name%></div>
                <div class="left_1-3"><%=user.profession%></div>
                <div class="left_1icons">
                    <a class="link_href" href="">
                        <div class="icon">
                            <img src="icon/dribbble.svg" alt="">
                        </div>
                    </a>
                    <a class="link_href" href="">
                        <div class="icon">
                            <img src="icon/instagram.svg" class="icon-1" alt="">
                        </div>
                    </a>
                    <a class="link_href" href="">
                        <div class="icon">
                            <img src="icon/linkedin.svg" class="icon-1" alt="">
                        </div>
                    </a>
                    <a class="link_href" href="">
                        <div class="icon">
                            <img src="icon/youtube.svg" class="icon-1" alt="">
                        </div>
                    </a>
                    <a class="link_href" href="">
                        <div class="icon">
                            <img src="icon/twitter.svg" class="icon-1" alt="">
                        </div>
                    </a>
                </div>
            </div>
            <div class="marginer"></div>
            <div class="left_2">
                <div class="left_2-1">
                    <div class="">
                     <span class="info">Age:</span>
                     <span class=""><%=user.age%></span>
                    </div>
                    <div class="">
                     <span class="info">Residence:</span>
                     <span class=""><%=user.residence%></span>
                    </div>
                    <div class="">
                     <span class="info">freelance:</span>
                     <span class="in">available</span>
                    </div>
                    <div class="">
                     <span class="info">Adress:</span>
                     <span class=""><%=user.adress%></span>
                    </div>
                </div>
            </div>
            <div class="marginer"></div>
            <div class="left_3">
                <div class="sidebar-card">
                  <h3 class="languages">Languages</h3>
                  <div class="left_3-lan">
                    <div><%=user.languages[0]%></div>
                    <div>100%</div>
                  </div>
                  <div class="left_3-line"></div>
                  <div class="left_3-lan">
                    <div><%=user.languages[1]%></div>
                    <div>80%</div>
                  </div>
                  <div class="left_3-line"></div>
                  <div class="left_3-lan">
                    <div><%=user.languages[2]%></div>
                    <div>60%</div>
                  </div>
                  <div class="left_3-line"></div>
                </div>
            </div>
            <div class="marginer"></div>
            <div class="left_4">
                <h3>Skills</h3>
                <div class="left_4-1">
                    <div><%=user.skills[0]%></div>
                    <div>90%</div>
                </div>
                <div class="progress">
                   <div class="progress-bar" style="width: 90%;"></div>
                </div>
                <div class="left_4-1">
                    <div><%=user.skills[1]%></div>
                    <div>85%</div>
                </div>
                <div class="progress">
                   <div class="progress-bar" style="width: 85%;"></div>
                </div>
                <div class="left_4-1">
                    <div><%=user.skills[2]%></div>
                    <div>80%</div>
                </div>
                <div class="progress">
                   <div class="progress-bar" style="width: 80%;"></div>
                </div>
                <div class="left_4-1">
                    <div><%=user.skills[3]%></div>
                    <div>75%</div>
                </div>
                <div class="progress">
                   <div class="progress-bar" style="width: 75%;"></div>
                </div>
                <div class="left_4-1">
                    <div><%=user.skills[4]%></div>
                    <div>85%</div>
                </div>
                <div class="progress">
                   <div class="progress-bar" style="width: 85%;"></div>
                </div>
            </div>
            <div class="marginer"></div>
            <div class="left_5"></div>
            <div class="marginer"></div>
        </div>
         <div class="midd_frame"></div>
          <div class="right_frame"></div>
    </div>
   </div> 
</body>

</html>